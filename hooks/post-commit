#!/usr/bin/env bash
# git-commitors: post-commit hook
# Reads author selection and amends the commit

set -euo pipefail

# Guard: recursion from our own amend
[[ "${GIT_COMMITORS_AMENDING:-}" == "1" ]] && exit 0

GIT_DIR_PATH="$(git rev-parse --git-dir)"
SELECTION_FILE="$GIT_DIR_PATH/gc-author-selection"

# No selection file — nothing to do
[[ -f "$SELECTION_FILE" ]] || exit 0

# Read selection
name=""
email=""
gpgkey=""

while IFS='=' read -r key value; do
    case "$key" in
        name)   name="$value" ;;
        email)  email="$value" ;;
        gpgkey) gpgkey="$value" ;;
    esac
done < "$SELECTION_FILE"

# Remove selection file immediately
rm -f "$SELECTION_FILE"

# Validate
if [[ -z "$name" || -z "$email" ]]; then
    exit 0
fi

# Build amend command
amend_args=(commit --amend --no-edit --no-verify --allow-empty)
amend_args+=(--author="$name <$email>")

# GPG signing
if [[ -n "$gpgkey" ]]; then
    amend_args+=("-S$gpgkey")
else
    amend_args+=(--no-gpg-sign)
fi

# Execute amend with recursion guard
GIT_COMMITORS_AMENDING=1 git "${amend_args[@]}" >/dev/null 2>&1 || true

exit 0
